DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/astrowise

# LLM provider: "anthropic" (default) | "nim" (NVIDIA) | "openai" | "gemini"
LLM_PROVIDER=nim

# Option A — NVIDIA NIM (free tier available at build.nvidia.com)
NIM_API_KEY=nvapi-...
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Option B — Anthropic Claude (comment out if using NIM)
# ANTHROPIC_API_KEY=sk-ant-...

# Demo access codes (bypasses Razorpay for testing)
DEMO_SECRET=change-this-secret

RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...
JWT_SECRET=change-me-to-random-64-chars
FRONTEND_URL=https://astrowyze.netlify.app
